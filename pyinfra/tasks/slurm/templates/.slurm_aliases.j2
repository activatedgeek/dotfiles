function __sbatch {
    local kind="cpu" sbatch_args=()
    local sbatch_cmd=(
        sbatch
        --signal=B:USR1@10
        -A {{ sbatch_account }}
    )

    {% set gpu_partition = sbatch_partitions.gpu %}
    {% set cpu_partition = sbatch_partitions.cpu if sbatch_partitions.cpu is defined else gpu_partition %}

    while [[ $# -gt 0 ]]; do
        case "${1}" in
            --gpus-per-node)
                kind="gpu"
                {% if gpu_partition.overrides is defined %}
                {% if gpu_partition.overrides.gpus_per_node is defined and gpu_partition.overrides.gpus_per_node > 0 %}
                sbatch_args+=("${1}" {{ gpu_partition.overrides.gpus_per_node }})
                {% endif %}
                {% else %}
                sbatch_args+=("${1}" "${2}")
                {% endif %}
                shift 2
            ;;
            *) sbatch_args+=("${1}"); shift ;;
      esac
    done

    if [[ "${kind}" == "gpu" ]]; then
        sbatch_cmd+=(
            -p {{ gpu_partition.partition }}
            {% if gpu_partition.qos is defined %}
            -q {{ gpu_partition.qos }}
            {% endif %}
        )
    else
        sbatch_cmd+=(
            -p {{ cpu_partition.partition }}
            {% if cpu_partition.qos is defined %}
            -q {{ cpu_partition.qos }}
            {% endif %}
        )
    fi

    sbatch_cmd+=(
        -t 4:00:00
        -J {{ sbatch_account }}-sbatch.$(basename $(pwd))
        "${sbatch_args[@]}"
    )

    echo "${sbatch_cmd[*]}"
    "${sbatch_cmd[@]}"
}

function __srun {
    local kind="cpu" srun_args=()
    local srun_cmd=(
        srun
        --pty
        --no-container-mount-home
        -A {{ sbatch_account }}
    )

    {% set gpu_partition = sbatch_partitions.gpu_interactive %}
    {% set cpu_partition = sbatch_partitions.cpu_interactive if sbatch_partitions.cpu_interactive is defined else gpu_partition %}

    while [[ $# -gt 0 ]]; do
        case "${1}" in
            --gpus-per-node)
                kind="gpu"
                {% if gpu_partition.overrides is defined %}
                {% if gpu_partition.overrides.gpus_per_node is defined and gpu_partition.overrides.gpus_per_node > 0 %}
                srun_args+=("${1}" {{ gpu_partition.overrides.gpus_per_node }})
                {% endif %}
                {% else %}
                srun_args+=("${1}" "${2}")
                {% endif %}
                shift 2
            ;;
            *) srun_args+=("${1}"); shift ;;
      esac
    done

    if [[ "${kind}" == "gpu" ]]; then
        srun_cmd+=(
            -p {{ gpu_partition.partition }}
            {% if gpu_partition.qos is defined %}
            -q {{ gpu_partition.qos }}
            {% endif %}
        )
    else
        srun_cmd+=(
            -p {{ cpu_partition.partition }}
            {% if cpu_partition.qos is defined %}
            -q {{ cpu_partition.qos }}
            {% endif %}
        )
    fi

    srun_cmd+=(
        -t 2:00:00
        -J {{ sbatch_account }}-srun.$(basename $(pwd))
        "${srun_args[@]}"
    )

    echo "${srun_cmd[*]}"
    "${srun_cmd[@]}"
}
