{
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow"
    }
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "codex-acp": {
      "default_config_options": {
        "mode": "auto"
      },
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    },
    "opencode": {
      "favorite_config_option_values": {
        "model": [
          "opencode/nemotron-3-ultra-free"
        ]
      },
      "type": "registry"
    }
  },
  "base_keymap": "VSCode",
  "buffer_font_fallbacks": [
    "Menlo",
    "Monaco",
    "Courier New",
    "monospace"
  ],
  "buffer_font_family": "Inconsolata Nerd Font",
  "buffer_font_size": 18.0,
  "cli_default_open_behavior": "new_window",
  "diagnostics_max_severity": "off",
  "diff_view_style": "unified",
  "file_types": {},
  "format_on_save": "off",
  "icon_theme": {
    "mode": "system",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },
  "line_numbers": true,
  "minimap": {
    "show": "auto"
  },
  "project_panel": {
    "dock": "left"
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  },
  "theme": "Catppuccin Frappé",
  "ui_font_size": 16
}
