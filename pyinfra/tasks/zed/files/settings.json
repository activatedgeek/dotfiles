{
  "agent_servers": {
    "cursor": {
       "favorite_config_option_values": {
         "model": [
           "composer-2[fast=true]",
           "claude-opus-4-6[thinking=true,context=200k,effort=high,fast=false]"
         ]
       },
       "type": "registry"
     },
    "claude-acp": {
      "favorite_config_option_values": {
        "model": [
          "opus[1m]"
        ]
      },
      "type": "registry"
    }
  },
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "ollama",
      "model": "minimax-m2.7",
      "enable_thinking": true
    },
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "diagnostics": {
          "default": "allow"
        },
        "fetch": {
          "default": "allow"
        },
        "find_path": {
          "default": "allow",
        },
        "grep": {
          "default": "allow",
        },
        "list_directory": {
          "default": "allow",
        },
        "now": {
          "default": "allow",
        },
        "read_file": {
          "default": "allow",
        }
      }
    }
  },
  "language_models": {
    "ollama": {
      "api_url": "https://ollama.com"
    }
  },
  "base_keymap": "VSCode",
  "buffer_font_fallbacks": [
    "Menlo",
    "Monaco",
    "Courier New",
    "monospace"
  ],
  "buffer_font_family": "Inconsolata Nerd Font",
  "buffer_font_size": 18.0,
  "diagnostics_max_severity": "off",
  "file_types": {},
  "format_on_save": "off",
  "icon_theme": {
    "mode": "system",
    "light": "Material Icon Theme",
    "dark": "Zed (Default)"
  },
  "line_numbers": true,
  "minimap": {
    "show": "auto"
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  },
  "theme": "Gruvbox Dark Soft",
  "ui_font_size": 16
}
