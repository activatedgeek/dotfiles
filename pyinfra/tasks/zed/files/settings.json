{
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow"
    }
  },
  "agent_servers": {
    "cursor": {
       "favorite_config_option_values": {
         "model": [
           "composer-2[fast=true]",
           "claude-opus-4-6[thinking=true,context=200k,effort=high,fast=false]"
         ]
       },
       "type": "registry"
     },
    "claude-acp": {
      "favorite_config_option_values": {
        "model": [
          "opus[1m]"
        ]
      },
      "type": "registry"
    }
  },
  "base_keymap": "VSCode",
  "buffer_font_fallbacks": [
    "Menlo",
    "Monaco",
    "Courier New",
    "monospace"
  ],
  "buffer_font_family": "Inconsolata Nerd Font",
  "buffer_font_size": 18.0,
  "diagnostics_max_severity": "off",
  "diff_view_style": "unified",
  "file_types": {},
  "format_on_save": "off",
  "icon_theme": {
    "mode": "system",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },
  "language_models": {
    "ollama": {
      "api_url": "https://ollama.com"
    }
  },
  "line_numbers": true,
  "minimap": {
    "show": "auto"
  },
  "project_panel": {
    "dock": "left"
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  },
  "theme": "Catppuccin Frappé",
  "ui_font_size": 16
}
